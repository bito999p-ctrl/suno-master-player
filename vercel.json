{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "player.js",
      "use": "@vercel/static"
    },
    {
      "src": "audio-engine.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/suno",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
